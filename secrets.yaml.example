# Copy this file to secrets.yaml (same folder) and fill in the real value.
# secrets.yaml is gitignored so the password never lands in source control.
#
# The mitsubishi2MQTT web UI password (all four units share the same one).
# The username is hard-coded to "admin" in the firmware, so only the password
# is a secret.
mitsubishi_web_password: "your-device-web-password"
